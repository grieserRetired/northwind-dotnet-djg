@page
@model NorthwindDotNet.Web.Pages.Companies.IndexModel
@{
    ViewData["Title"] = "Companies";
}

<h1 class="mb-4">Companies</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
else if (!Model.Companies.Any())
{
    <div class="alert alert-info">No companies found. Make sure the API is running at http://localhost:5132.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Company</th>
                <th>Type</th>
                <th>Phone</th>
                <th>City</th>
                <th>State</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Companies
                .OrderBy(c => c.CompanyType?.CompanyTypeName)
                .ThenBy(c => c.CompanyName))
            {
                <tr>
                    <td>@c.CompanyName</td>
                    <td>
                        <span class="badge @TypeBadge(c.CompanyType?.CompanyTypeName)">
                            @c.CompanyType?.CompanyTypeName
                        </span>
                    </td>
                    <td>@c.BusinessPhone</td>
                    <td>@c.City</td>
                    <td>@c.StateAbbrev</td>
                </tr>
            }
        </tbody>
    </table>
}

@functions {
    static string TypeBadge(string? type) => type switch
    {
        "Customer"  => "bg-primary",
        "Vendor"    => "bg-success",
        "Shipper"   => "bg-info text-dark",
        "Northwind" => "bg-warning text-dark",
        _           => "bg-secondary"
    };
}
